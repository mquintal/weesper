{
  "name": "admin",
  "version": "0.0.1-alpha.13",
  "private": true,
  "description": "High-performance local transcription powered by AI",
  "author": "Miguel Quintal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mquintal/weesper.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:inspect": "NODE_OPTIONS='--inspect-brk' vite",
    "generate-icons": "bash ../../scripts/generate-icons.sh",
    "build": "yarn generate-icons && tsc && vite build && electron-builder",
    "build:ci": "yarn generate-icons && tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check src electron",
    "reset:permissions": "tccutil reset Microphone com.apple.Terminal && tccutil reset Accessibility com.apple.Terminal",
    "clean": "rm -rf dist && rm -rf dist-electron",
    "clean:data": "rm -rf ~/Library/Application\\ Support/Weesper",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -v 41.5.0 -w better-sqlite3",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:node": "vitest run --config vitest.config.node.ts",
    "test": "yarn test:node",
    "test:watch": "vitest --config vitest.config.node.ts"
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "@weesper/config": "workspace:*",
    "@weesper/database": "workspace:*",
    "@weesper/hooks": "workspace:*",
    "@weesper/ipc": "workspace:*",
    "@weesper/logger": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "electron-log": "^5.4.3",
    "electron-updater": "6.8.3",
    "execa": "^9.6.1",
    "tree-kill": "^1.2.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/react": "^10.51.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "4.2",
    "@tanstack/react-query": "^5.100.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/hark": "^1.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "classnames": "^2.5.1",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "framer-motion": "^12.38.0",
    "hark": "^1.2.3",
    "lottie-react": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "storybook": "^10.3.6",
    "tailwindcss": "4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^3.1.2"
  },
  "build": {
    "appId": "com.weesper.app",
    "productName": "Weesper",
    "electronVersion": "41.5.0",
    "copyright": "",
    "directories": {
      "output": "release/${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "mquintal",
      "repo": "weesper"
    },
    "files": [
      "dist",
      "dist-electron",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*",
          "!models/**/*",
          "!llms/**/*",
          "!db/**/*",
          "!recordings/**/*",
          "!db/**/*"
        ]
      }
    ],
    "compression": "maximum",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "weesper_v${version}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Weesper needs access to your microphone to transcribe your speech into text.",
        "NSAccessibilityUsageDescription": "Weesper needs accessibility access to provide global shortcuts and interact with other applications for transcription.",
        "CFBundleName": "Weesper",
        "CFBundleDisplayName": "Weesper",
        "CFBundleIdentifier": "com.weesper.app",
        "CFBundleIconFile": "icon.icns",
        "NSHumanReadableCopyright": ""
      },
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    }
  }
}
