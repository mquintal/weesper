---
const features = [
  {
    title: '100% Offline',
    description: 'Everything runs on your machine. No internet required, no cloud dependencies, no data ever leaves your computer.',
    icon: '🛡️',
  },
  {
    title: 'Local Transcription',
    description: 'Powered by whisper.cpp it transcribes fast, accurate speech-to-text running locally on your hardware.',
    icon: '🎙️',
  },
  {
    title: 'AI Text Enhancement',
    description: 'Optionally rewrite, reformat, or correct your transcript using a local llama.cpp LLM with custom prompts.',
    icon: '✨',
  },
  {
    title: 'Transcript History',
    description: 'Never lose a transcription again Weesper keeps your audio and transcript history organized.',
    icon: '📋',
  },
  {
    title: 'Apple Silicon Optimized',
    description: 'Built for macOS with native performance on both Apple Silicon (ARM64) and Intel (x64) processors.',
    icon: '⚡',
  },
  {
    title: 'Privacy First',
    description: 'Your recordings and transcriptions stay on your device. No accounts and no cloud uploads.',
    icon: '🔒',
  },
]
---

<section id="features" class="border-t border-white/10 px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-center text-3xl font-bold text-white sm:text-4xl">Why Weesper?</h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-gray-400">
      A desktop tool built for privacy, speed, and simplicity.
    </p>
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-xl border border-white/10 bg-white/5 p-6 transition-colors hover:border-white/20">
            <div class="mb-4 text-2xl">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-400">{f.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
