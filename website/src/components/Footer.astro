---
const year = new Date().getFullYear()
---

<footer class="border-t border-white/10 px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
    <div class="flex items-center gap-2 text-sm text-gray-500">
      <img src="/weesper/favicon.svg" alt="" class="h-5 w-5" />
      <span>&copy; {year} Weesper</span>
    </div>
    <div class="flex items-center gap-6 text-sm">
      <a
        href="https://github.com/mquintal/weesper"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-500 transition-colors hover:text-white"
      >
        GitHub
      </a>
      <a
        href="https://github.com/mquintal/weesper/blob/main/LICENSE.md"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-500 transition-colors hover:text-white"
      >
        License
      </a>
    </div>
  </div>
</footer>
