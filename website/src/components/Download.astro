---
const res = await fetch(
  'https://api.github.com/repos/mquintal/weesper/releases/latest',
  { headers: { Accept: 'application/vnd.github+json' } },
)

let version: string | null = null
let tagName: string | null = null
if (res.ok) {
  const release = await res.json()
  tagName = release.tag_name
  version = tagName?.replace(/^v/, '') ?? 'unknown'
}
---

<section id="download" class="border-t border-white/10 px-6 py-24">
  <div class="mx-auto max-w-4xl text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">Download Weesper</h2>
    <p class="mx-auto mt-4 max-w-2xl text-gray-400">
      Available for macOS 13+. Choose your architecture below.
    </p>

    {
      version ? (
        <>
          <div class="mt-4 inline-block rounded-full bg-[#FFAD00]/10 px-4 py-1 text-sm text-[#FFAD00]">
            Latest version: v{version}
          </div>
          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={`https://github.com/mquintal/weesper/releases/latest/download/weesper_v${version}_arm64.dmg`}
              class="inline-flex w-full max-w-xs flex-col items-center gap-1 rounded-xl border border-white/20 bg-white/5 px-8 py-5 transition-all hover:bg-white/10 hover:shadow-lg"
            >
              <span class="text-lg font-semibold text-white">Apple Silicon</span>
              <span class="text-sm text-gray-400">ARM64 &bull; M1 / M2 / M3 / M4</span>
            </a>
            <a
              href={`https://github.com/mquintal/weesper/releases/latest/download/weesper_v${version}_x64.dmg`}
              class="inline-flex w-full max-w-xs flex-col items-center gap-1 rounded-xl border border-white/20 bg-white/5 px-8 py-5 transition-all hover:bg-white/10 hover:shadow-lg"
            >
              <span class="text-lg font-semibold text-white">Intel</span>
              <span class="text-sm text-gray-400">x64 &bull; Macs with Intel processors</span>
            </a>
          </div>
          <p class="mt-6 text-sm text-gray-500">
            All assets available on <a href="https://github.com/mquintal/weesper/releases/latest" class="text-[#FFAD00] underline underline-offset-2 transition-colors hover:text-[#FFC107]">GitHub Releases</a>
          </p>
        </>
      ) : (
        <div class="mt-10 rounded-xl border border-white/10 bg-white/5 p-8">
          <p class="text-lg text-gray-300">No release available yet.</p>
          <p class="mt-2 text-sm text-gray-500">
            Check back soon, or build from source on
            <a href="https://github.com/mquintal/weesper" class="text-[#FFAD00] underline underline-offset-2">GitHub</a>.
          </p>
        </div>
      )
    }
  </div>
</section>
