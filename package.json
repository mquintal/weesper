{
  "name": "open-bisbis",
  "private": true,
  "author": "Miguel Quintal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mquintal/open-bisbis.git"
  },
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace admin dev",
    "dev:inspect": "yarn workspace admin dev:inspect",
    "build": "yarn workspace admin build",
    "build:ci": "yarn workspace admin build:ci",
    "lint": "biome check .",
    "knip": "knip",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "yarn workspaces foreach -A run clean && rm -rf node_modules",
    "build-deps": "./scripts/build-ffmpeg.sh && ./scripts/build-whisper.sh && ./scripts/build-llama.sh",
    "prepare": "husky",
    "test": "yarn workspaces foreach -A run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "knip": "^6.14.1"
  },
  "resolutions": {
    "@sentry/browser": "10.51.0",
    "@sentry/core": "10.51.0",
    "@sentry/node": "10.51.0",
    "@sentry/types": "10.51.0"
  },
  "version": "0.0.1-alpha.12"
}
